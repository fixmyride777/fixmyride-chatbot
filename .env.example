ANTHROPIC_API_KEY=your_key_here
WASENDER_API_TOKEN=your_wasender_token_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MEMORY_TTL_MS=1800000
MAX_CONVERSATION_MESSAGES=24

# Advisor number for handoff_human (Supabase). Defaults: table advisor_numbers, column phone_number.
# ADVISOR_NUMBERS_TABLE=advisor_numbers
# ADVISOR_PHONE_COLUMN=phone_number
# ADVISOR_FILTER_ACTIVE_ONLY=true
# Optional: also WhatsApp the advisor via Wasender (same token as customer messages).
# HANDOFF_SEND_WASENDER_TO_ADVISOR=false

# Chatbot personality from Supabase (prepended to system prompt). Defaults: table chatbot_personality, column content.
# CHATBOT_PERSONALITY_TABLE=chatbot_personality
# CHATBOT_PERSONALITY_COLUMN=content
# Optional: CHATBOT_PERSONALITY_ORDER_BY=updated_at
# CHATBOT_PERSONALITY_ORDER_ASC=false
